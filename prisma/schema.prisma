generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BEHIND
  FAST_PACED
  PUT_TO_REVISE
}

enum RoadmapPhase {
  STUDYING
  REVISION
}

enum TaskType {
  LECTURE
  NOTES
  PRACTICE
  PYQ
  REVISION
  TEST
  MOCK
  MOCK_ANALYSIS
  FORMULA_REVISION
  MISTAKE_ANALYSIS
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum RoadmapStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roadmaps     UserRoadmap[]
  testAttempts TestAttempt[]
  studyLogs    StudyLog[]
  studySessions StudySession[]
}

model UserRoadmap {
  id               String        @id @default(cuid())
  userId           String
  title            String
  startDate        DateTime
  endDate          DateTime
  totalDays        Int
  studyingDays     Int
  revisionDays     Int
  status           RoadmapStatus @default(ACTIVE)
  overallProgress  Float         @default(0)
  studyingProgress Float         @default(0)
  revisionProgress Float         @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  days             RoadmapDay[]
  tasks            RoadmapTask[]
  subjectProgress  SubjectProgress[]
  topicProgress    TopicProgress[]
  subtopicProgress SubtopicProgress[]
  testAttempts     TestAttempt[]
  studyLogs        StudyLog[]
  studySessions    StudySession[]
}

model RoadmapDay {
  id                  String         @id @default(cuid())
  userRoadmapId        String
  dayNumber            Int
  date                 DateTime
  phase                RoadmapPhase
  title                String
  description          String?
  subjectName          String?
  completionPercentage Float          @default(0)
  status               ProgressStatus @default(NOT_STARTED)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  userRoadmap UserRoadmap  @relation(fields: [userRoadmapId], references: [id], onDelete: Cascade)
  tasks       RoadmapTask[]

  @@unique([userRoadmapId, dayNumber])
  @@index([userRoadmapId, date])
}

model RoadmapTask {
  id               String         @id @default(cuid())
  roadmapDayId     String
  userRoadmapId    String
  subjectName      String
  topicName        String?
  subtopicName     String?
  title            String
  description      String?
  taskType         TaskType
  estimatedMinutes Int            @default(30)
  actualMinutes    Int?
  priority         Priority       @default(MEDIUM)
  order            Int            @default(0)
  status           ProgressStatus @default(NOT_STARTED)
  selfRating       Int?
  notes            String?
  plannedDate      DateTime
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  roadmapDay  RoadmapDay  @relation(fields: [roadmapDayId], references: [id], onDelete: Cascade)
  userRoadmap UserRoadmap @relation(fields: [userRoadmapId], references: [id], onDelete: Cascade)
  studySessions StudySession[]

  @@index([userRoadmapId, plannedDate])
  @@index([userRoadmapId, subjectName])
  @@index([userRoadmapId, topicName])
  @@index([userRoadmapId, subtopicName])
}

model StudySession {
  id              String   @id @default(cuid())
  userId          String
  userRoadmapId   String?
  roadmapTaskId   String?

  sessionType     String
  subjectName     String?
  topicName       String?
  subtopicName    String?

  title           String?
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int      @default(0)

  plannedSeconds  Int?
  pausedSeconds   Int      @default(0)
  pausedAt        DateTime?

  status          String   @default("RUNNING")
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userRoadmap     UserRoadmap?  @relation(fields: [userRoadmapId], references: [id], onDelete: SetNull)
  roadmapTask     RoadmapTask?  @relation(fields: [roadmapTaskId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([userRoadmapId])
  @@index([roadmapTaskId])
}

model SubjectProgress {
  id                 String         @id @default(cuid())
  userRoadmapId       String
  subjectName         String
  totalTopics         Int            @default(0)
  completedTopics     Int            @default(0)
  totalSubtopics      Int            @default(0)
  completedSubtopics  Int            @default(0)
  status              ProgressStatus @default(NOT_STARTED)
  progressPercentage  Float          @default(0)
  confidenceScore     Float?
  lastStudiedAt       DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  userRoadmap UserRoadmap @relation(fields: [userRoadmapId], references: [id], onDelete: Cascade)

  @@unique([userRoadmapId, subjectName])
}

model TopicProgress {
  id                 String         @id @default(cuid())
  userRoadmapId       String
  subjectName         String
  topicName           String
  totalSubtopics      Int            @default(0)
  completedSubtopics  Int            @default(0)
  status              ProgressStatus @default(NOT_STARTED)
  progressPercentage  Float          @default(0)
  confidenceScore     Float?
  lastStudiedAt       DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  userRoadmap UserRoadmap @relation(fields: [userRoadmapId], references: [id], onDelete: Cascade)

  @@unique([userRoadmapId, subjectName, topicName])
}

model SubtopicProgress {
  id                 String         @id @default(cuid())
  userRoadmapId       String
  subjectName         String
  topicName           String
  subtopicName        String
  plannedDate         DateTime?
  status              ProgressStatus @default(NOT_STARTED)
  progressPercentage  Float          @default(0)
  confidenceScore     Float?
  revisionPriority    Int            @default(0)
  notes               String?
  lastStudiedAt       DateTime?
  completedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  userRoadmap UserRoadmap @relation(fields: [userRoadmapId], references: [id], onDelete: Cascade)

  @@unique([userRoadmapId, subjectName, topicName, subtopicName])
}

model TestAttempt {
  id               String   @id @default(cuid())
  userId           String
  userRoadmapId    String
  title            String
  testType         String
  subjectName      String?
  score            Float
  totalMarks       Float
  accuracy         Float?
  timeTakenMinutes Int?
  mistakes         Json?
  weakTopics       Json?
  notes            String?
  attemptedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userRoadmap UserRoadmap @relation(fields: [userRoadmapId], references: [id], onDelete: Cascade)
}

model StudyLog {
  id             String   @id @default(cuid())
  userId         String
  userRoadmapId  String
  date           DateTime
  minutesStudied Int      @default(0)
  tasksCompleted Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userRoadmap UserRoadmap @relation(fields: [userRoadmapId], references: [id], onDelete: Cascade)

  @@unique([userId, userRoadmapId, date])
}
